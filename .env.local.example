# Copy this file to .env.local (already gitignored) and fill in your own values.

# --- OpenRouter -------------------------------------------------------
# Get a key from https://openrouter.ai/keys
# Used server-side only (src/lib/llm/openrouter.ts) to extract topics/entities/
# summaries from captured conversations for the Timeline and Knowledge Graph
# views. If left unset, conversations still import fine — they just won't
# have insights, and Timeline/Graph will show them ungrouped.
OPENROUTER_API_KEY=

# --- Supabase ----------------------------------------------------------
# From your Supabase project: Settings -> API -> Project URL / anon public key.
# Run supabase/schema.sql in the SQL Editor once before starting the app.
# Both stores (conversations, personas, the Dashboard's recovery store, and
# capsules) read/write Supabase using these — the app won't start without
# them once the storage layers are switched over.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App secret key -----------------------------------------------------
# A random string YOU generate (e.g. `openssl rand -hex 24`) — not from any
# external service. The anon key above is public by design (it ships in the
# browser bundle), so on its own + a permissive RLS policy it would let
# anyone who finds it read/write your data. This key closes that gap.
# Used server-side only — never exposed to client code or shipped in bundles.
# After setting this, also run the `alter database ... set app.settings.
# personamd_access_key = '...'` statement at the bottom of supabase/schema.sql
# with this same value, then restart the dev server.
# Treat this like a password — do not share it or commit it.
APP_SECRET_KEY=

# --- JWT secret ---------------------------------------------------------
# Another random string (e.g. `openssl rand -hex 32`) used to sign session tokens.
# Used server-side only — never exposed to client code or shipped in bundles.
# Treat this like a password — do not share it or commit it.
JWT_SECRET_KEY=
